# MongoDB Telemetry Storage Configuration (Optional - Defaults to SQLite app/runs.db if unset)
MONGODB_URI=
MONGODB_DB=tsp_solver

# MLflow Experiment Tracking Server Configuration (Optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Hugging Face Hub Dataset Configuration (Optional - Defaults to local storage if unset)
HF_TOKEN=
HF_DATASET_REPO=

# Force training on specific device (Optional - e.g., 'cuda' or 'cpu'. If 'cuda' and no GPU exists, training aborts)
FORCE_DEVICE=
